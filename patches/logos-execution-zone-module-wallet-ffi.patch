+static bool jsonToFfiRecipientIdentifier(const QString& json, FfiU128* output_identifier) {
+    QJsonDocument doc = QJsonDocument::fromJson(json.toUtf8());
+    if (!doc.isObject())
+        return false;
+    const QVariantMap map = doc.object().toVariantMap();
+
+    QString identifierHex;
+    if (map.contains(JsonKeys::Identifier)) {
+        identifierHex = map[JsonKeys::Identifier].toString();
+    } else if (map.contains(JsonKeys::ToIdentifier)) {
+        identifierHex = map[JsonKeys::ToIdentifier].toString();
+    } else if (map.contains(JsonKeys::IdentifierLe16Hex)) {
+        identifierHex = map[JsonKeys::IdentifierLe16Hex].toString();
+    } else {
+        return false;
+    }
+
+    return hexToFfiU128(identifierHex, output_identifier);
+}
